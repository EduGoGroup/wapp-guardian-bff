# wapp-guardian-bff — variables de entorno (prefijo WAPP_). Copia a .env y ajusta. Sin secretos aquí.

# Ambiente lógico: "local" (permisivo, sin TLS) o cualquier otro (endurece Secure cookie + HSTS).
WAPP_GUARDIAN_ENV=local

# Dirección de escucha del BFF (host:port). Banda 81xx de wApp.
WAPP_GUARDIAN_HTTP_ADDR=:8104

# URL base de la API pública REST de la plataforma (:8103 /api/v1). Único interlocutor del BFF.
WAPP_PUBLIC_API_BASE=http://localhost:8103

# --- Cookie de sesión (JWT server-side, HttpOnly siempre) ---
# Secure: true en producción (TLS). En local false. Default: true salvo ENV=local.
WAPP_GUARDIAN_COOKIE_SECURE=false
# SameSite: lax | strict | none. "none" obliga Secure=true.
WAPP_GUARDIAN_COOKIE_SAMESITE=lax

# --- CORS (fail-closed) ---
# Allowlist CSV de orígenes completos (p. ej. https://consola.wapp.test). Vacío == same-origin. NUNCA "*".
WAPP_GUARDIAN_ALLOWED_ORIGINS=

# --- HSTS ---
# Emite Strict-Transport-Security (solo tras TLS). Default: sigue a COOKIE_SECURE.
WAPP_GUARDIAN_HSTS_ENABLED=false

# --- Rate-limit (en memoria, por IP/usuario) ---
WAPP_GUARDIAN_RATE_ENABLED=true
WAPP_GUARDIAN_RATE_RPS=5
WAPP_GUARDIAN_RATE_BURST=10

# --- Timeouts del http.Server (segundos, anti-slowloris) ---
WAPP_GUARDIAN_READ_HEADER_TIMEOUT_SECS=5
WAPP_GUARDIAN_READ_TIMEOUT_SECS=15
WAPP_GUARDIAN_WRITE_TIMEOUT_SECS=30
WAPP_GUARDIAN_IDLE_TIMEOUT_SECS=60
